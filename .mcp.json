{
  "mcpServers": {
    "eql-hosted": {
      "type": "http",
      "url": "https://za.encore.io/gateway/api/mcp-eql/",
      "headers": {
        "Authorization": "Bearer ${ENCORE_EQL_TOKEN}"
      }
    },
    "socai": {
      "type": "stdio",
      "command": "bash",
      "args": ["-c", "cd /home/will/socai && exec python3 -m mcp_server"],
      "env": {
        "SOCAI_MCP_TRANSPORT": "stdio"
      }
    }
  }
}
