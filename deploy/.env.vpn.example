# Gluetun environment for Mullvad WireGuard VPN sidecar.
# Copy to .env.vpn and fill in your values.
#
# Get WireGuard credentials from: https://mullvad.net/en/account/wireguard-config
# Generate a key, pick a server country, download the config.
# Copy PrivateKey and Address from the [Interface] section.

VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your-wireguard-private-key-here
WIREGUARD_ADDRESSES=10.x.x.x/32
SERVER_COUNTRIES=Serbia
HTTPPROXY=on
HTTPPROXY_LISTENING_ADDRESS=:8888
HEALTH_VPN_DURATION_INITIAL=10s
HEALTH_VPN_DURATION_ADDITION=5s
